# Public site URL used later for metadata, canonical links, and deployment-aware sharing.
NEXT_PUBLIC_SITE_URL=

# Base URL for the external products source. Leave blank to use DummyJSON.
PRODUCTS_API_BASE_URL=

# Optional. Set to true only when you want to bypass Next image optimization
# for DummyJSON-hosted product images during noisy local preview/debug runs.
BYPASS_REMOTE_IMAGE_OPTIMIZATION=
